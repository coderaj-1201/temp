# ── Retrieval Pipeline — Local Dev .env ───────────────────────────────────────
# Copy this to container-code/.env and fill in your values.
# Auth: run `az login` once. No keys needed for Foundry, Search, Service Bus, CosmosDB.

# ── Azure AI Foundry ──────────────────────────────────────────────────────────
# Portal: AI Foundry → your project → Overview → "Project endpoint"
AZURE_FOUNDRY_PROJECT_ENDPOINT=https://<hub>.services.ai.azure.com/api/projects/<project>
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_EVAL_DEPLOYMENT=gpt-4o-mini

# ── Azure AI Search ───────────────────────────────────────────────────────────
# Portal: AI Search → Overview → Url
AZURE_SEARCH_ENDPOINT=https://<name>.search.windows.net
AZURE_SEARCH_INDEX=idx-rag
AZURE_SEARCH_SEMANTIC_CONFIG=rag-semantic-config

# ── Azure Service Bus ─────────────────────────────────────────────────────────
# Portal: Service Bus namespace → Overview → Host name
# IMPORTANT: rag-inbound and rag-outbound queues must have Sessions ENABLED
AZURE_SERVICE_BUS_NAMESPACE=<namespace>.servicebus.windows.net

# ── Azure Cosmos DB ───────────────────────────────────────────────────────────
# Portal: Cosmos DB → Overview → URI
AZURE_COSMOS_ENDPOINT=https://<account>.documents.azure.com:443/
AZURE_COSMOS_DATABASE=rag-analytics
AZURE_COSMOS_CONTAINER_EVALUATIONS=evaluations
AZURE_COSMOS_CONTAINER_FEEDBACK=feedback

# ── Entra ID — leave blank for local dev (JWT auth is bypassed) ───────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=

# ── RAG tuning ────────────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.75
MAX_RETRIEVAL_ATTEMPTS=3
RETRIEVAL_TOP_K=5
SYNTHESIS_TEMPERATURE=0.0

# ── Observability — optional locally ─────────────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=
LOG_LEVEL=INFO
