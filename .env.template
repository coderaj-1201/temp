# ── Copy this to .env ─────────────────────────────────────────────────────────

# Azure AI Foundry project endpoint
# Portal: AI Foundry → your project → Overview → Project endpoint
# CLI:    az ml workspace show --name <project> --resource-group <rg> --query properties.discoveryUrl -o tsv
AZURE_FOUNDRY_PROJECT_ENDPOINT=https://<hub>.services.ai.azure.com/api/projects/<project>

# Deployment names — Portal: AI Foundry → your project → Deployments tab
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Azure AI Search
# Endpoint — Portal: AI Search resource → Overview → Url
# API Key  — Portal: AI Search resource → Settings → Keys → Primary admin key
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_API_KEY=<primary-admin-key>
AZURE_SEARCH_INDEX_HR=idx-hr
AZURE_SEARCH_INDEX_LEGAL=idx-legal
AZURE_SEARCH_INDEX_IT=idx-it
AZURE_SEARCH_SEMANTIC_CONFIG=default

# Azure Service Bus — leave blank for local dev (RETRIEVAL_MODE=http)
AZURE_SERVICE_BUS_CONNECTION_STR=
AZURE_SERVICE_BUS_QUEUE_INBOUND=rag-inbound
AZURE_SERVICE_BUS_QUEUE_OUTBOUND=rag-outbound

# RAG Tuning
CONFIDENCE_THRESHOLD=0.75
MAX_RETRIEVAL_ATTEMPTS=3
RETRIEVAL_TOP_K=5
SYNTHESIS_TEMPERATURE=0.0

# Agent URLs (local dev)
MAIN_AGENT_URL=http://localhost:8000
ORCHESTRATOR_AGENT_URL=http://localhost:8001
RETRIEVAL_AGENT_URL=http://localhost:8002
RETRIEVAL_MODE=http

# Teams Bot (optional for local dev)
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=

# Observability (optional)
APPLICATIONINSIGHTS_CONNECTION_STRING=
LOG_LEVEL=INFO
